{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate && prisma db push --skip-generate --accept-data-loss && tsx watch src/index.ts",
    "build": "prisma generate",
    "start": "prisma generate && prisma db push --skip-generate --accept-data-loss && tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pulseforge/shared": "workspace:*",
    "@prisma/client": "^6.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "catalog:",
    "prisma": "^6.9.0",
    "tsx": "catalog:",
    "typescript": "~5.9.3"
  }
}
