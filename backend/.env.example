DATABASE_URL="file:./data/pulseforge.db"
PORT=4000
# Optional — when set, /api/* routes require X-PulseForge-Key (cloud routes use bearer).
# PULSEFORGE_API_SECRET=your_api_secret_here
# Bootstrap admin bearer — full cloud access (Settings → paste token).
# Per-device sessions are created via POST /api/cloud/auth/session (no env needed).
PULSEFORGE_SYNC_TOKEN=your_sync_secret_here

MUSIXMATCH_API_KEY=
CYANITE_ACCESS_TOKEN=
# Webhook secret from Cyanite integration (for verifying signatures on async analysis callbacks)
CYANITE_WEBHOOK_SECRET=
SONGSTATS_API_KEY=
# Optional JSON trend keyword feed (merged with curated seasonal list). Example: {"keywords":["summer","vibe"],"moods":["Party"]}
# TREND_FEED_URL=
ELEVENLABS_API_KEY=
LALAL_API_KEY=
JAMBASE_API_KEY=
N8N_WEBHOOK_URL=  # Production webhook URL from n8n (https://.../webhook/your-path)