DATABASE_URL="file:./data/pulseforge.db"
PORT=4000
# Optional — when set, /api/* routes require X-PulseForge-Key (cloud routes use bearer).
# PULSEFORGE_API_SECRET=your_api_secret_here
# Bootstrap admin bearer — full cloud access (Settings → paste token).
PULSEFORGE_SYNC_TOKEN=your_sync_secret_here

# ── Musixmatch (Musicathon Pro) ─────────────────────────────────────────────
# Catalog search, lyrics, moods/themes, richsync, analysis search
# Also enables Stem Separation API (professional grade stems)
MUSIXMATCH_API_KEY=
# Alias accepted by client code:
# MXM_KEY=

# ── Cyanite ─────────────────────────────────────────────────────────────────
# Spotify-track audio AI: BPM, energy curve, mood/genre/instrument tags
CYANITE_ACCESS_TOKEN=
# For future async webhook callbacks (optional):
CYANITE_WEBHOOK_SECRET=

# ── Songstats ───────────────────────────────────────────────────────────────
# Cross-platform streams, playlists, TikTok, Shazam, historic velocity
SONGSTATS_API_KEY=

# ── ElevenLabs ──────────────────────────────────────────────────────────────
# Hook TTS, voice clone, full song (Music API), music stem separation
ELEVENLABS_API_KEY=
# Optional default voice for TTS:
# ELEVENLABS_VOICE_ID=

# ── LALAL.AI ──────────────────────────────────────────────────────────────
# Production multistem separation in Produce tab
LALAL_API_KEY=

# ── JamBase ─────────────────────────────────────────────────────────────────
# Live concert listings on Launch tab (demo data when unset)
JAMBASE_API_KEY=

# ── n8n ─────────────────────────────────────────────────────────────────────
# Release automation webhook — hit score, Songstats, Cyanite, JamBase context
N8N_WEBHOOK_URL=

# ── Optional trend feed ───────────────────────────────────────────────────────
# JSON merged with curated seasonal keywords for lyric trend scoring
# TREND_FEED_URL=https://example.com/trends.json
